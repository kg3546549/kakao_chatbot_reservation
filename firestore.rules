rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isPlatformAdmin() {
      return signedIn() && request.auth.token.platformAdmin == true;
    }

    function membership(tenantId) {
      return get(/databases/$(database)/documents/tenants/$(tenantId)/members/$(request.auth.uid));
    }

    function isTenantActive(tenantId) {
      return get(/databases/$(database)/documents/tenants/$(tenantId)).data.status == "active";
    }

    function isTenantMember(tenantId) {
      return signedIn()
        && isTenantActive(tenantId)
        && exists(/databases/$(database)/documents/tenants/$(tenantId)/members/$(request.auth.uid))
        && membership(tenantId).data.status == "active";
    }

    function isHumanMember(tenantId) {
      return isTenantMember(tenantId)
        && membership(tenantId).data.role in ["owner", "manager", "viewer"];
    }

    function canManageTenant(tenantId) {
      return isPlatformAdmin()
        || (isTenantMember(tenantId)
          && membership(tenantId).data.role in ["owner", "manager"]);
    }

    match /users/{userId} {
      allow read, update: if signedIn() && request.auth.uid == userId;
      allow create: if signedIn() && request.auth.uid == userId;

      match /tenantMemberships/{tenantId} {
        allow read: if signedIn() && request.auth.uid == userId;
        allow write: if false;
      }
    }

    match /tenants/{tenantId} {
      allow read: if isTenantMember(tenantId) || isPlatformAdmin();
      allow write: if false;

      match /members/{userId} {
        allow read: if isHumanMember(tenantId) || isPlatformAdmin();
        allow write: if false;
      }

      match /devices/{deviceId} {
        allow read: if isPlatformAdmin()
          || isHumanMember(tenantId)
          || (isTenantMember(tenantId)
            && resource.data.uid == request.auth.uid);
        allow write: if false;
      }

      match /items/{itemId} {
        allow read: if isHumanMember(tenantId);
        allow write: if canManageTenant(tenantId);
      }

      match /rooms/{roomId} {
        allow read: if isHumanMember(tenantId);
        allow write: if canManageTenant(tenantId);
      }

      match /reservationEvents/{eventId} {
        allow read: if isHumanMember(tenantId);
        allow write: if false;
      }

      match /currentReservations/{reservationId} {
        allow read: if isHumanMember(tenantId);
        allow write: if false;
      }

      match /dailyStats/{date} {
        allow read: if isHumanMember(tenantId);
        allow write: if false;
      }

      match /auditLogs/{logId} {
        allow read: if isPlatformAdmin()
          || (isTenantMember(tenantId)
            && membership(tenantId).data.role == "owner");
        allow write: if false;
      }
    }
  }
}
